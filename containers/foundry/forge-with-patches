#!/usr/bin/env bash
set -euo pipefail

source_dir="${FORGE_SOURCE_DIR:-/work}"
workspace="${FORGE_PATCHED_WORKDIR:-/tmp/forge-work}"
manifest="${source_dir}/dependency-patches.txt"

fail() {
  printf 'forge-with-patches: %s\n' "$1" >&2
  exit 2
}

require_safe_relative_path() {
  case "$1" in
    ""|/*|../*|*/../*|*/..)
      fail "unsafe relative path: $1" ;;
  esac
}

strip_dependencies_table() {
  awk '
    /^\[dependencies\][[:space:]]*$/ { skip = 1; next }
    /^\[/ { skip = 0 }
    !skip { print }
  ' "${source_dir}/foundry.toml" > "${workspace}/foundry.toml"
}

prepare_workspace() {
  rm -rf "${workspace}"
  mkdir -p "${workspace}"

  cp -a "${source_dir}/contracts" "${workspace}/contracts"
  cp -a "${source_dir}/dependencies" "${workspace}/dependencies"
  cp "${source_dir}/remappings.txt" "${workspace}/remappings.txt"
  strip_dependencies_table
}

apply_dependency_patches() {
  if [ ! -f "${manifest}" ]; then
    return
  fi

  while read -r dependency target patch_file pre_hash patch_hash post_hash extra; do
    case "${dependency:-}" in
      ""|\#*) continue ;;
    esac

    if [ -n "${extra:-}" ]; then
      fail "malformed patch manifest line for ${dependency}"
    fi

    require_safe_relative_path "${dependency}"
    require_safe_relative_path "${target}"
    require_safe_relative_path "${patch_file}"

    case "${dependency}" in
      */*) fail "dependency key must be a single directory name: ${dependency}" ;;
    esac

    target_path="${workspace}/dependencies/${dependency}/${target}"
    patch_path="${source_dir}/${patch_file}"

    [ -f "${target_path}" ] || fail "missing dependency patch target: ${target_path}"
    [ -f "${patch_path}" ] || fail "missing dependency patch file: ${patch_path}"

    printf '%s  %s\n' "${pre_hash}" "${target_path}" | sha256sum -c -
    printf '%s  %s\n' "${patch_hash}" "${patch_path}" | sha256sum -c -
    patch --directory="${workspace}/dependencies/${dependency}" --strip=1 --forward --batch --input="${patch_path}"
    printf '%s  %s\n' "${post_hash}" "${target_path}" | sha256sum -c -
  done < "${manifest}"
}

prepare_workspace
apply_dependency_patches

cd "${workspace}"
export FOUNDRY_CONFIG="${workspace}/foundry.toml"
exec forge "$@"
