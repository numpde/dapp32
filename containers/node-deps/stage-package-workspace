#!/bin/sh
set -eu

source_dir="${1:?missing source package workspace directory}"
target_dir="${2:?missing target package workspace directory}"

if [ "$source_dir" != "/input/packages" ] || [ "$target_dir" != "/work/packages" ]; then
  printf '%s\n' "stage-package-workspace only supports /input/packages -> /work/packages" >&2
  exit 2
fi

test -d "$source_dir"
test -d "$target_dir"
find "$target_dir" -mindepth 1 -maxdepth 1 ! -name node_modules -exec rm -rf -- {} +

reject_symlink() {
  path="${1:?missing path}"
  if [ -L "$path" ]; then
    printf 'stage-package-workspace refuses symlink input: %s\n' "$path" >&2
    exit 2
  fi
}

copy_file_if_present() {
  path="${1:?missing source file}"
  name="${path##*/}"

  if [ -e "$path" ]; then
    reject_symlink "$path"
    if [ ! -f "$path" ]; then
      printf 'stage-package-workspace expected a file: %s\n' "$path" >&2
      exit 2
    fi
    cp -a "$path" "$target_dir/$name"
  fi
}

workspace_patterns="$(
  node -e '
    const fs = require("node:fs");
    const manifest = JSON.parse(fs.readFileSync("/input/packages/package.json", "utf8"));
    const workspaces = Array.isArray(manifest.workspaces)
      ? manifest.workspaces
      : manifest.workspaces && Array.isArray(manifest.workspaces.packages)
        ? manifest.workspaces.packages
        : null;
    if (!workspaces) process.exit(2);
    for (const workspace of workspaces) {
      if (typeof workspace !== "string") process.exit(2);
      console.log(workspace);
    }
  '
)" || {
  printf '%s\n' 'stage-package-workspace could not read npm workspaces from /input/packages/package.json' >&2
  exit 2
}

reject_symlink "$source_dir/package.json"
copy_file_if_present "$source_dir/package.json"
copy_file_if_present "$source_dir/package-lock.json"
copy_file_if_present "$source_dir/tsconfig.base.json"
copy_file_if_present "$source_dir/tsconfig.package.json"
copy_file_if_present "$source_dir/tsconfig.test.json"

for pattern in $workspace_patterns; do
  case "$pattern" in
    */* | *"**"* | "!"* | *"!"*)
      printf 'stage-package-workspace supports only first-level positive workspace globs: %s\n' "$pattern" >&2
      exit 2
      ;;
  esac

  matched=0
  for package_dir in "$source_dir"/$pattern; do
    [ -d "$package_dir" ] || continue
    matched=1
    package_name="${package_dir##*/}"
    manifest="$package_dir/package.json"

    reject_symlink "$package_dir"
    reject_symlink "$manifest"
    if [ ! -f "$manifest" ]; then
      printf 'stage-package-workspace expected a package manifest: %s\n' "$manifest" >&2
      exit 2
    fi

    rm -rf "$target_dir/$package_name"
    mkdir "$target_dir/$package_name"
    cp -a "$manifest" "$target_dir/$package_name/package.json"

    for child in "$package_dir"/*; do
      [ -e "$child" ] || continue
      child_name="${child##*/}"
      case "$child_name" in
        dist | node_modules | package.json)
          continue
          ;;
      esac
      reject_symlink "$child"
      cp -a "$child" "$target_dir/$package_name/$child_name"
    done
  done

  if [ "$matched" != "1" ]; then
    printf 'stage-package-workspace workspace matched no packages: %s\n' "$pattern" >&2
    exit 2
  fi
done
