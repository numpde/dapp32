#!/bin/sh
set -eu

if [ "$#" -eq 0 ]; then
  printf '%s\n' 'run-js-workspace requires a command' >&2
  exit 2
fi

stage-js-workspace /input/js /work/js
cd /work/js
npm_graph=/tmp/js-graph-check.json
if ! npm ls --all --workspaces --ignore-scripts --offline --omit=optional --json >"$npm_graph"; then
  # npm reports an overridden exact transitive dependency as invalid even when
  # the lock resolves the reviewed security replacement. Keep the exception
  # narrow so one temporary vulnerability pin does not mask graph drift.
  node - "$npm_graph" <<'NODE'
const fs = require("node:fs")

const graphPath = process.argv[2]
const graph = JSON.parse(fs.readFileSync(graphPath, "utf8"))
const manifest = JSON.parse(fs.readFileSync("package.json", "utf8"))
const lock = JSON.parse(fs.readFileSync("package-lock.json", "utf8"))
const allowedProblem = "invalid: ws@8.21.0 /work/js/node_modules/ws"
const problems = Array.isArray(graph.problems) ? graph.problems : []
const unexpected = problems.filter((problem) => problem !== allowedProblem)

if (unexpected.length !== 0) {
  console.error(`npm dependency graph has unexpected problem(s):\n${unexpected.join("\n")}`)
  process.exit(1)
}
if (problems.length !== 1) {
  console.error("npm dependency graph failed without the expected ws security-override problem")
  process.exit(1)
}
if (manifest.overrides?.ws !== "8.21.0") {
  console.error("js/package.json must keep the reviewed ws security override")
  process.exit(1)
}
if (lock.packages?.["node_modules/ws"]?.version !== "8.21.0") {
  console.error("js/package-lock.json must resolve the reviewed ws security override")
  process.exit(1)
}
NODE
fi

exec "$@"
