{
  "cam": "1.0.0",
  "entry": "entry",
  "namespaces": {
    "contracts.BicycleComponentManagerUI": {
      "type": "contract",
      "abiURI": "./abi/BicycleComponentManagerUI.json",
      "integrity": "sha256:0x35ac513bc468bf5d27cdc65c8bd94e5f13013384b96bacf9960596594e1f4b10"
    },
    "contracts.BicycleComponentManager": {
      "type": "contract",
      "abiURI": "./abi/BicycleComponentManager.json",
      "integrity": "sha256:0x79799b5e6f26d796af04de48ac89fb7074cd42d6d28c4064071f74663fdcb794"
    },
    "routes": {
      "type": "routes"
    },
    "ui": {
      "type": "ui",
      "uri": "./ui.json",
      "integrity": "sha256:0x8e64d9dd0c8fb5dcdd32f91d48aa399ba01a3eceb50069ff466e5e56e20c3017"
    }
  },
  "routes": {
    "entry": {
      "kind": "read",
      "inputs": [],
      "call": {
        "namespace": "contracts.BicycleComponentManagerUI",
        "function": "viewEntry",
        "args": {
          "account": "$account.address"
        }
      },
      "then": {
        "namespace": "ui",
        "function": "app",
        "args": {
          "view": "$outputs.0"
        }
      }
    },
    "component": {
      "kind": "read",
      "inputs": ["serialNumber"],
      "call": {
        "namespace": "contracts.BicycleComponentManagerUI",
        "function": "viewComponent",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "account": "$account.address"
        }
      },
      "then": {
        "namespace": "ui",
        "function": "app",
        "args": {
          "view": "$outputs.0"
        }
      }
    },
    "register": {
      "kind": "read",
      "inputs": ["serialNumber"],
      "call": {
        "namespace": "contracts.BicycleComponentManagerUI",
        "function": "viewRegister",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "account": "$account.address"
        }
      },
      "then": {
        "namespace": "ui",
        "function": "app",
        "args": {
          "view": "$outputs.0"
        }
      }
    },
    "registerComponent": {
      "kind": "write",
      "inputs": ["serialNumber", "tokenURI"],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "registerComponent",
        "args": {
          "owner": "$account.address",
          "serialNumber": "$inputs.serialNumber",
          "tokenURI_": "$inputs.tokenURI"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "updateComponentMetadata": {
      "kind": "write",
      "inputs": ["serialNumber", "tokenURI"],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "setComponentMetadata",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "tokenURI_": "$inputs.tokenURI"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "markComponentMissing": {
      "kind": "write",
      "inputs": ["serialNumber"],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "markMissing",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "clearComponentMissing": {
      "kind": "write",
      "inputs": ["serialNumber"],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "clearMissing",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "retireComponent": {
      "kind": "write",
      "inputs": ["serialNumber"],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "retireComponent",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    }
  }
}
