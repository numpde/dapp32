{
  "cam": "1.0.0",
  "entry": "entry",
  "namespaces": {
    "contracts.BicycleComponentManagerUI": {
      "type": "contract",
      "abiURI": "./abi/BicycleComponentManagerUI.json",
      "integrity": "sha256:0x27a16e7ea597a34bf3158a06dfa3f21b04e461df269f4cbbd2269de48ef59348"
    },
    "contracts.BicycleComponentManager": {
      "type": "contract",
      "abiURI": "./abi/BicycleComponentManager.json",
      "integrity": "sha256:0xb527349030bedd520ac6dba32168cd20ad82328268b060bcb7c0d858b23cfac6"
    },
    "routes": {
      "type": "routes"
    },
    "ui": {
      "type": "ui",
      "uri": "./ui.json",
      "integrity": "sha256:0x9367ff1b241f40d2c117ce071b5112cc6cf858d7aed7f353185923e4727a2811"
    }
  },
  "routes": {
    "entry": {
      "kind": "read",
      "inputs": [],
      "call": {
        "namespace": "contracts.BicycleComponentManagerUI",
        "function": "viewEntry",
        "args": {
          "account": "$account.address"
        }
      },
      "then": {
        "namespace": "ui",
        "function": "app",
        "args": {
          "view": "$outputs.0"
        }
      }
    },
    "component": {
      "kind": "read",
      "inputs": [
        "serialNumber"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManagerUI",
        "function": "viewComponent",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "account": "$account.address"
        }
      },
      "then": {
        "namespace": "ui",
        "function": "app",
        "args": {
          "view": "$outputs.0"
        }
      }
    },
    "register": {
      "kind": "read",
      "inputs": [
        "serialNumber"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManagerUI",
        "function": "viewRegister",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "account": "$account.address"
        }
      },
      "then": {
        "namespace": "ui",
        "function": "app",
        "args": {
          "view": "$outputs.0"
        }
      }
    },
    "registerComponent": {
      "kind": "write",
      "inputs": [
        "owner",
        "serialNumber",
        "tokenURI"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "registerComponent",
        "args": {
          "owner": "$inputs.owner",
          "serialNumber": "$inputs.serialNumber",
          "tokenURI_": "$inputs.tokenURI"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "setAccountInfo": {
      "kind": "write",
      "inputs": [
        "accountInfo"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "setAccountInfo",
        "args": {
          "infoURI": "$inputs.accountInfo"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "entry",
        "args": {}
      }
    },
    "updateComponentMetadata": {
      "kind": "write",
      "inputs": [
        "serialNumber",
        "tokenURI"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "setComponentMetadata",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "tokenURI_": "$inputs.tokenURI"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "markComponentMissing": {
      "kind": "write",
      "inputs": [
        "serialNumber",
        "reportURI"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "markComponentMissing",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "reportURI": "$inputs.reportURI"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "clearComponentMissing": {
      "kind": "write",
      "inputs": [
        "serialNumber",
        "resolutionURI"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "clearComponentMissing",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "resolutionURI": "$inputs.resolutionURI"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "retireComponent": {
      "kind": "write",
      "inputs": [
        "serialNumber"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "retireComponent",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    }
  }
}
