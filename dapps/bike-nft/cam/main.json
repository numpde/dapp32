{
  "cam": "1.0.0",
  "entry": "entry",
  "namespaces": {
    "contracts.BicycleComponentManagerUI": {
      "type": "contract",
      "abiURI": "./abi/BicycleComponentManagerUI.json",
      "integrity": "sha256:0xca6cc02b960e230f3e0fbd1eecdf801d23aef4a88dbf8a5ddf833e37850ba3ed"
    },
    "contracts.BicycleComponentManager": {
      "type": "contract",
      "abiURI": "./abi/BicycleComponentManager.json",
      "integrity": "sha256:0xcc36dbe7a334a5ad3de990a532fa44530fcc9063aead9ba05fe7f16872b79c37"
    },
    "routes": {
      "type": "routes"
    },
    "ui": {
      "type": "ui",
      "uri": "./ui.json",
      "integrity": "sha256:0x4aa73daabc2c1de37e7b45e37d5be4320d85c8f6b4fbf95d1e4e8300fa430b94"
    }
  },
  "routes": {
    "entry": {
      "kind": "read",
      "inputs": [],
      "call": {
        "namespace": "contracts.BicycleComponentManagerUI",
        "function": "viewEntry",
        "args": {
          "account": "$account.address"
        }
      },
      "then": {
        "namespace": "ui",
        "function": "app",
        "args": {
          "view": "$outputs.0"
        }
      }
    },
    "component": {
      "kind": "read",
      "inputs": [
        "serialNumber"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManagerUI",
        "function": "viewComponent",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "account": "$account.address"
        }
      },
      "then": {
        "namespace": "ui",
        "function": "app",
        "args": {
          "view": "$outputs.0"
        }
      }
    },
    "register": {
      "kind": "read",
      "inputs": [
        "serialNumber"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManagerUI",
        "function": "viewRegister",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "account": "$account.address"
        }
      },
      "then": {
        "namespace": "ui",
        "function": "app",
        "args": {
          "view": "$outputs.0"
        }
      }
    },
    "registerComponent": {
      "kind": "write",
      "inputs": [
        "serialNumber",
        "tokenURI"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "registerComponent",
        "args": {
          "owner": "$account.address",
          "serialNumber": "$inputs.serialNumber",
          "tokenURI_": "$inputs.tokenURI"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "updateComponentMetadata": {
      "kind": "write",
      "inputs": [
        "serialNumber",
        "tokenURI"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "setComponentMetadata",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "tokenURI_": "$inputs.tokenURI"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "markComponentMissing": {
      "kind": "write",
      "inputs": [
        "serialNumber",
        "reportURI"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "markComponentMissing",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "reportURI": "$inputs.reportURI"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "clearComponentMissing": {
      "kind": "write",
      "inputs": [
        "serialNumber",
        "resolutionURI"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "clearComponentMissing",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "resolutionURI": "$inputs.resolutionURI"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "retireComponent": {
      "kind": "write",
      "inputs": [
        "serialNumber"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "retireComponent",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    }
  }
}
