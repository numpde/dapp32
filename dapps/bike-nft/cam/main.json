{
  "cam": "1.0.0",
  "entry": "entry",
  "namespaces": {
    "contracts.BicycleComponentManagerUI": {
      "type": "contract",
      "abiURI": "./abi/BicycleComponentManagerUI.json",
      "integrity": "sha256:0xca6cc02b960e230f3e0fbd1eecdf801d23aef4a88dbf8a5ddf833e37850ba3ed"
    },
    "contracts.BicycleComponentManager": {
      "type": "contract",
      "abiURI": "./abi/BicycleComponentManager.json",
      "integrity": "sha256:0x79799b5e6f26d796af04de48ac89fb7074cd42d6d28c4064071f74663fdcb794"
    },
    "routes": {
      "type": "routes"
    },
    "ui": {
      "type": "ui",
      "uri": "./ui.json",
      "integrity": "sha256:0x18e9620c64352b81d94cecc0e74c6706c55c1436028aa9762e7ca84d61cbe4e0"
    }
  },
  "routes": {
    "entry": {
      "kind": "read",
      "inputs": [],
      "call": {
        "namespace": "contracts.BicycleComponentManagerUI",
        "function": "viewEntry",
        "args": {
          "account": "$account.address"
        }
      },
      "then": {
        "namespace": "ui",
        "function": "app",
        "args": {
          "view": "$outputs.0"
        }
      }
    },
    "component": {
      "kind": "read",
      "inputs": [
        "serialNumber"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManagerUI",
        "function": "viewComponent",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "account": "$account.address"
        }
      },
      "then": {
        "namespace": "ui",
        "function": "app",
        "args": {
          "view": "$outputs.0"
        }
      }
    },
    "register": {
      "kind": "read",
      "inputs": [
        "serialNumber"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManagerUI",
        "function": "viewRegister",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "account": "$account.address"
        }
      },
      "then": {
        "namespace": "ui",
        "function": "app",
        "args": {
          "view": "$outputs.0"
        }
      }
    },
    "registerComponent": {
      "kind": "write",
      "inputs": [
        "serialNumber",
        "tokenURI"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "registerComponent",
        "args": {
          "owner": "$account.address",
          "serialNumber": "$inputs.serialNumber",
          "tokenURI_": "$inputs.tokenURI"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "updateComponentMetadata": {
      "kind": "write",
      "inputs": [
        "serialNumber",
        "tokenURI"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "setComponentMetadata",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "tokenURI_": "$inputs.tokenURI"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "markComponentMissing": {
      "kind": "write",
      "inputs": [
        "serialNumber"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "markMissing",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "clearComponentMissing": {
      "kind": "write",
      "inputs": [
        "serialNumber"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "clearMissing",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "retireComponent": {
      "kind": "write",
      "inputs": [
        "serialNumber"
      ],
      "call": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "retireComponent",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    }
  }
}
