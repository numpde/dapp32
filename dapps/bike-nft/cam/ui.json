{
  "ui": "1.0.0",
  "nodes": {
    "app": {
      "element": "Screen",
      "requires": [
        "view"
      ],
      "props": {
        "title": "Bicycle component registry"
      },
      "children": [
        {
          "element": "Include",
          "call": {
            "namespace": "ui",
            "function": "$view.viewId",
            "args": {
              "view": "$view"
            }
          }
        },
        {
          "element": "Include",
          "call": {
            "namespace": "ui",
            "function": "$view.actions",
            "args": {
              "view": "$view"
            }
          }
        }
      ]
    },
    "entry": {
      "requires": [
        "view"
      ],
      "element": "Fragment",
      "children": [
        {
          "element": "Text",
          "props": {
            "text": "Look up a component by the serial number stamped on the bicycle."
          }
        },
        {
          "element": "Address",
          "props": {
            "label": "Connected account",
            "address": "$view.account"
          }
        },
        {
          "element": "Status",
          "props": {
            "label": "Can register components",
            "value": "$view.canRegister"
          }
        },
        {
          "element": "TextField",
          "props": {
            "label": "Account info URI"
          },
          "state": {
            "key": "accountInfo",
            "defaultValue": "$view.accountInfo"
          }
        },
        {
          "element": "TextField",
          "props": {
            "label": "Serial number"
          },
          "state": {
            "key": "serialNumber",
            "defaultValue": "$view.serialNumber"
          }
        }
      ]
    },
    "component.empty": {
      "requires": [
        "view"
      ],
      "element": "Fragment",
      "children": [
        {
          "element": "Text",
          "props": {
            "text": "Enter a bicycle component serial number."
          }
        },
        {
          "element": "TextField",
          "props": {
            "label": "Serial number"
          },
          "state": {
            "key": "serialNumber",
            "defaultValue": "$view.serialNumber"
          }
        }
      ]
    },
    "component.notFound": {
      "requires": [
        "view"
      ],
      "element": "Fragment",
      "children": [
        {
          "element": "TextField",
          "props": {
            "label": "Serial number"
          },
          "state": {
            "key": "serialNumber",
            "defaultValue": "$view.serialNumber"
          }
        },
        {
          "element": "Status",
          "props": {
            "label": "Registered",
            "value": false
          }
        }
      ]
    },
    "component.found": {
      "requires": [
        "view"
      ],
      "element": "Fragment",
      "children": [
        {
          "element": "TextField",
          "props": {
            "label": "Serial number"
          },
          "state": {
            "key": "serialNumber",
            "defaultValue": "$view.serialNumber"
          }
        },
        {
          "element": "Status",
          "props": {
            "label": "Status",
            "value": "$view.statusId"
          }
        },
        {
          "element": "Address",
          "props": {
            "label": "Owner",
            "address": "$view.owner"
          }
        },
        {
          "element": "Status",
          "props": {
            "label": "Owner info",
            "value": "$view.ownerInfo"
          }
        },
        {
          "element": "Nft",
          "props": {
            "contractAddress": "$view.tokenContract",
            "tokenId": "$view.tokenId"
          }
        },
        {
          "element": "Status",
          "props": {
            "label": "Token URI",
            "value": "$view.tokenURI"
          }
        },
        {
          "element": "Status",
          "props": {
            "label": "Serial hash",
            "value": "$view.serialHash"
          }
        }
      ]
    },
    "component.active": {
      "requires": [
        "view"
      ],
      "element": "Fragment",
      "children": [
        {
          "element": "Include",
          "call": {
            "namespace": "ui",
            "function": "component.found",
            "args": {
              "view": "$view"
            }
          }
        },
        {
          "element": "TextField",
          "props": {
            "label": "New token URI"
          },
          "state": {
            "key": "tokenURI",
            "defaultValue": "$view.tokenURI"
          }
        },
        {
          "element": "TextField",
          "props": {
            "label": "Missing report URI"
          },
          "state": {
            "key": "reportURI",
            "defaultValue": ""
          }
        }
      ]
    },
    "component.missing": {
      "requires": [
        "view"
      ],
      "element": "Fragment",
      "children": [
        {
          "element": "Include",
          "call": {
            "namespace": "ui",
            "function": "component.found",
            "args": {
              "view": "$view"
            }
          }
        },
        {
          "element": "TextField",
          "props": {
            "label": "New token URI"
          },
          "state": {
            "key": "tokenURI",
            "defaultValue": "$view.tokenURI"
          }
        },
        {
          "element": "Status",
          "props": {
            "label": "Missing report URI",
            "value": "$view.missingReportURI"
          }
        },
        {
          "element": "TextField",
          "props": {
            "label": "Resolution URI"
          },
          "state": {
            "key": "resolutionURI",
            "defaultValue": ""
          }
        }
      ]
    },
    "component.retired": {
      "requires": [
        "view"
      ],
      "element": "Include",
      "call": {
        "namespace": "ui",
        "function": "component.found",
        "args": {
          "view": "$view"
        }
      }
    },
    "register.empty": {
      "requires": [
        "view"
      ],
      "element": "Fragment",
      "children": [
        {
          "element": "Text",
          "props": {
            "text": "Enter a serial number before preparing registration."
          }
        },
        {
          "element": "TextField",
          "props": {
            "label": "Serial number"
          },
          "state": {
            "key": "serialNumber",
            "defaultValue": "$view.serialNumber"
          }
        },
        {
          "element": "TextField",
          "props": {
            "label": "Token URI"
          },
          "state": {
            "key": "tokenURI",
            "defaultValue": "$view.tokenURI"
          }
        }
      ]
    },
    "register.ready": {
      "requires": [
        "view"
      ],
      "element": "Fragment",
      "children": [
        {
          "element": "TextField",
          "props": {
            "label": "Serial number"
          },
          "state": {
            "key": "serialNumber",
            "defaultValue": "$view.serialNumber"
          }
        },
        {
          "element": "TextField",
          "props": {
            "label": "Token URI"
          },
          "state": {
            "key": "tokenURI",
            "defaultValue": "$view.tokenURI"
          }
        },
        {
          "element": "Address",
          "props": {
            "label": "Component contract",
            "address": "$view.componentsAddress"
          }
        },
        {
          "element": "Status",
          "props": {
            "label": "Account info",
            "value": "$view.accountInfo"
          }
        }
      ]
    },
    "register.blocked": {
      "requires": [
        "view"
      ],
      "element": "Fragment",
      "children": [
        {
          "element": "TextField",
          "props": {
            "label": "Serial number"
          },
          "state": {
            "key": "serialNumber",
            "defaultValue": "$view.serialNumber"
          }
        },
        {
          "element": "Status",
          "props": {
            "label": "Connected account can register",
            "value": "$view.canRegister"
          }
        },
        {
          "element": "Status",
          "props": {
            "label": "Component already exists",
            "value": "$view.exists"
          }
        },
        {
          "element": "Status",
          "props": {
            "label": "Account info",
            "value": "$view.accountInfo"
          }
        }
      ]
    },
    "lookupComponent": {
      "requires": [
        "view"
      ],
      "element": "Button",
      "props": {
        "label": "Look up component"
      },
      "call": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$state.serialNumber"
        }
      }
    },
    "openRegister": {
      "requires": [
        "view"
      ],
      "element": "Button",
      "props": {
        "label": "Register component"
      },
      "call": {
        "namespace": "routes",
        "function": "register",
        "args": {
          "serialNumber": "$state.serialNumber"
        }
      }
    },
    "registerComponent": {
      "requires": [
        "view"
      ],
      "element": "Button",
      "props": {
        "label": "Prepare registration"
      },
      "call": {
        "namespace": "routes",
        "function": "registerComponent",
        "args": {
          "serialNumber": "$state.serialNumber",
          "tokenURI": "$state.tokenURI"
        }
      }
    },
    "setAccountInfo": {
      "requires": [
        "view"
      ],
      "element": "Button",
      "props": {
        "label": "Prepare account info update"
      },
      "call": {
        "namespace": "routes",
        "function": "setAccountInfo",
        "args": {
          "accountInfo": "$state.accountInfo"
        }
      }
    },
    "updateComponentMetadata": {
      "requires": [
        "view"
      ],
      "element": "Button",
      "props": {
        "label": "Prepare metadata update"
      },
      "call": {
        "namespace": "routes",
        "function": "updateComponentMetadata",
        "args": {
          "serialNumber": "$view.serialNumber",
          "tokenURI": "$state.tokenURI"
        }
      }
    },
    "markComponentMissing": {
      "requires": [
        "view"
      ],
      "element": "Button",
      "props": {
        "label": "Prepare missing report"
      },
      "call": {
        "namespace": "routes",
        "function": "markComponentMissing",
        "args": {
          "serialNumber": "$view.serialNumber",
          "reportURI": "$state.reportURI"
        }
      }
    },
    "clearComponentMissing": {
      "requires": [
        "view"
      ],
      "element": "Button",
      "props": {
        "label": "Prepare recovery resolution"
      },
      "call": {
        "namespace": "routes",
        "function": "clearComponentMissing",
        "args": {
          "serialNumber": "$view.serialNumber",
          "resolutionURI": "$state.resolutionURI"
        }
      }
    },
    "retireComponent": {
      "requires": [
        "view"
      ],
      "element": "Button",
      "props": {
        "label": "Prepare retirement"
      },
      "call": {
        "namespace": "routes",
        "function": "retireComponent",
        "args": {
          "serialNumber": "$view.serialNumber"
        }
      }
    }
  }
}
