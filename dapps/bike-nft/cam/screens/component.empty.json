{
  "screen": "1.0.0",
  "title": "Component lookup",
  "elements": [
    {
      "type": "text",
      "text": "Enter a bicycle component serial number."
    },
    {
      "type": "input",
      "name": "serialNumber",
      "label": "Serial number",
      "value": "$params.serialNumber"
    },
    {
      "type": "button",
      "label": "Look up component",
      "action": {
        "type": "navigate",
        "route": "component",
        "params": {
          "serialNumber": "$form.serialNumber"
        }
      }
    },
    {
      "type": "button",
      "label": "Register component",
      "action": {
        "type": "navigate",
        "route": "register",
        "params": {
          "serialNumber": "$form.serialNumber"
        }
      }
    }
  ]
}
