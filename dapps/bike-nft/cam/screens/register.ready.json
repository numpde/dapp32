{
  "screen": "1.0.0",
  "title": "Register component",
  "elements": [
    {
      "type": "input",
      "name": "serialNumber",
      "label": "Serial number",
      "value": "$values.0.serialNumber"
    },
    {
      "type": "input",
      "name": "tokenURI",
      "label": "Token URI",
      "value": ""
    },
    {
      "type": "button",
      "label": "Check registration",
      "action": {
        "type": "navigate",
        "route": "register",
        "params": {
          "serialNumber": "$form.serialNumber"
        }
      }
    },
    {
      "type": "address",
      "label": "Component contract",
      "address": "$values.0.componentsAddress"
    },
    {
      "type": "status",
      "label": "Account info",
      "value": "$values.0.accountInfo"
    },
    {
      "type": "button",
      "label": "Prepare registration",
      "action": {
        "type": "contract-call",
        "contract": "BicycleComponentManager",
        "function": "registerComponent",
        "args": [
          "$account.address",
          "$form.serialNumber",
          "$form.tokenURI"
        ],
        "onSuccess": {
          "type": "navigate",
          "route": "component",
          "params": {
            "serialNumber": "$form.serialNumber"
          }
        }
      }
    },
    {
      "type": "button",
      "label": "Open component",
      "action": {
        "type": "navigate",
        "route": "component",
        "params": {
          "serialNumber": "$form.serialNumber"
        }
      }
    }
  ]
}
