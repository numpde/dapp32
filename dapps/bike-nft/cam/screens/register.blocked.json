{
  "screen": "1.0.0",
  "title": "Registration unavailable",
  "elements": [
    {
      "type": "input",
      "name": "serialNumber",
      "label": "Serial number",
      "value": "$values.0.serialNumber"
    },
    {
      "type": "button",
      "label": "Check registration",
      "action": {
        "type": "navigate",
        "route": "register",
        "params": {
          "serialNumber": "$form.serialNumber"
        }
      }
    },
    {
      "type": "status",
      "label": "Connected account can register",
      "value": "$values.0.canRegister"
    },
    {
      "type": "status",
      "label": "Component already exists",
      "value": "$values.0.exists"
    },
    {
      "type": "status",
      "label": "Account info",
      "value": "$values.0.accountInfo"
    },
    {
      "type": "button",
      "label": "Open component",
      "action": {
        "type": "navigate",
        "route": "component",
        "params": {
          "serialNumber": "$form.serialNumber"
        }
      }
    }
  ]
}
