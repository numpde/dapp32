{
  "screen": "1.0.0",
  "title": "Register component",
  "elements": [
    {
      "type": "text",
      "text": "Enter a serial number before preparing registration."
    },
    {
      "type": "input",
      "name": "serialNumber",
      "label": "Serial number",
      "value": "$params.serialNumber"
    },
    {
      "type": "input",
      "name": "tokenURI",
      "label": "Token URI",
      "value": ""
    },
    {
      "type": "button",
      "label": "Check registration",
      "action": {
        "type": "navigate",
        "route": "register",
        "params": {
          "serialNumber": "$form.serialNumber"
        }
      }
    },
    {
      "type": "button",
      "label": "Open component",
      "action": {
        "type": "navigate",
        "route": "component",
        "params": {
          "serialNumber": "$form.serialNumber"
        }
      }
    }
  ]
}
