{
  "screen": "1.0.0",
  "title": "Component not found",
  "elements": [
    {
      "type": "input",
      "name": "serialNumber",
      "label": "Serial number",
      "value": "$values.0.serialNumber"
    },
    {
      "type": "button",
      "label": "Look up component",
      "action": {
        "type": "navigate",
        "route": "component",
        "params": {
          "serialNumber": "$form.serialNumber"
        }
      }
    },
    {
      "type": "status",
      "label": "Registered",
      "value": "$values.0.exists"
    },
    {
      "type": "button",
      "label": "Register component",
      "action": {
        "type": "navigate",
        "route": "register",
        "params": {
          "serialNumber": "$form.serialNumber"
        }
      }
    }
  ]
}
