{
  "screen": "1.0.0",
  "title": "Component",
  "elements": [
    {
      "type": "input",
      "name": "serialNumber",
      "label": "Serial number",
      "value": "$params.serialNumber"
    },
    {
      "type": "button",
      "label": "Look up component",
      "action": {
        "type": "navigate",
        "route": "component",
        "params": {
          "serialNumber": "$form.serialNumber"
        }
      }
    },
    {
      "type": "status",
      "label": "Current serial number",
      "value": "$values.0.serialNumber"
    },
    {
      "type": "status",
      "label": "Registered",
      "value": "$values.0.exists"
    },
    {
      "type": "group",
      "visibleWhen": "$values.0.exists",
      "elements": [
        {
          "type": "status",
          "label": "Status",
          "value": "$values.0.status"
        },
        {
          "type": "address",
          "label": "Owner",
          "address": "$values.0.owner"
        },
        {
          "type": "status",
          "label": "Owner info",
          "value": "$values.0.ownerInfo"
        },
        {
          "type": "address",
          "label": "Token contract",
          "address": "$values.0.tokenContract"
        },
        {
          "type": "status",
          "label": "Token ID",
          "value": "$values.0.tokenId"
        },
        {
          "type": "status",
          "label": "Token URI",
          "value": "$values.0.tokenURI"
        },
        {
          "type": "status",
          "label": "Serial hash",
          "value": "$values.0.serialHash"
        },
        {
          "type": "status",
          "label": "Can update metadata",
          "value": "$values.0.canUpdateMetadata"
        },
        {
          "type": "status",
          "label": "Can mark missing",
          "value": "$values.0.canMarkMissing"
        },
        {
          "type": "status",
          "label": "Can clear missing",
          "value": "$values.0.canClearMissing"
        },
        {
          "type": "status",
          "label": "Can retire",
          "value": "$values.0.canRetire"
        },
        {
          "type": "button",
          "visibleWhen": "$values.0.canMarkMissing",
          "label": "Prepare mark missing",
          "action": {
            "type": "contract-call",
            "contract": "BicycleComponentManager",
            "function": "markMissing",
            "args": [
              "$form.serialNumber"
            ],
            "onSuccess": {
              "type": "navigate",
              "route": "component",
              "params": {
                "serialNumber": "$form.serialNumber"
              }
            }
          }
        },
        {
          "type": "button",
          "visibleWhen": "$values.0.canClearMissing",
          "label": "Prepare clear missing",
          "action": {
            "type": "contract-call",
            "contract": "BicycleComponentManager",
            "function": "clearMissing",
            "args": [
              "$form.serialNumber"
            ],
            "onSuccess": {
              "type": "navigate",
              "route": "component",
              "params": {
                "serialNumber": "$form.serialNumber"
              }
            }
          }
        },
        {
          "type": "button",
          "visibleWhen": "$values.0.canRetire",
          "label": "Prepare retirement",
          "action": {
            "type": "contract-call",
            "contract": "BicycleComponentManager",
            "function": "retireComponent",
            "args": [
              "$form.serialNumber"
            ],
            "onSuccess": {
              "type": "navigate",
              "route": "component",
              "params": {
                "serialNumber": "$form.serialNumber"
              }
            }
          }
        }
      ]
    },
    {
      "type": "button",
      "label": "Open registration",
      "action": {
        "type": "navigate",
        "route": "register",
        "params": {
          "serialNumber": "$form.serialNumber"
        }
      }
    }
  ]
}
