{
  "screen": "1.0.0",
  "title": "Component",
  "elements": [
    {
      "type": "input",
      "name": "serialNumber",
      "label": "Serial number",
      "value": "$values.0.serialNumber"
    },
    {
      "type": "button",
      "label": "Look up component",
      "action": {
        "type": "navigate",
        "route": "component",
        "params": {
          "serialNumber": "$form.serialNumber"
        }
      }
    },
    {
      "type": "status",
      "label": "Status",
      "value": "$values.0.status"
    },
    {
      "type": "address",
      "label": "Owner",
      "address": "$values.0.owner"
    },
    {
      "type": "status",
      "label": "Owner info",
      "value": "$values.0.ownerInfo"
    },
    {
      "type": "address",
      "label": "Token contract",
      "address": "$values.0.tokenContract"
    },
    {
      "type": "status",
      "label": "Token ID",
      "value": "$values.0.tokenId"
    },
    {
      "type": "status",
      "label": "Token URI",
      "value": "$values.0.tokenURI"
    },
    {
      "type": "input",
      "name": "tokenURI",
      "label": "New token URI",
      "value": "$values.0.tokenURI"
    },
    {
      "type": "status",
      "label": "Serial hash",
      "value": "$values.0.serialHash"
    },
    {
      "type": "status",
      "label": "Can update metadata",
      "value": "$values.0.canUpdateMetadata"
    },
    {
      "type": "status",
      "label": "Can mark missing",
      "value": "$values.0.canMarkMissing"
    },
    {
      "type": "status",
      "label": "Can clear missing",
      "value": "$values.0.canClearMissing"
    },
    {
      "type": "status",
      "label": "Can retire",
      "value": "$values.0.canRetire"
    },
    {
      "type": "button",
      "label": "Prepare metadata update",
      "action": {
        "type": "contract-call",
        "contract": "BicycleComponentManager",
        "function": "setComponentMetadata",
        "args": [
          "$form.serialNumber",
          "$form.tokenURI"
        ],
        "onSuccess": {
          "type": "navigate",
          "route": "component",
          "params": {
            "serialNumber": "$form.serialNumber"
          }
        }
      }
    },
    {
      "type": "button",
      "label": "Prepare missing report",
      "action": {
        "type": "contract-call",
        "contract": "BicycleComponentManager",
        "function": "markMissing",
        "args": [
          "$form.serialNumber"
        ],
        "onSuccess": {
          "type": "navigate",
          "route": "component",
          "params": {
            "serialNumber": "$form.serialNumber"
          }
        }
      }
    },
    {
      "type": "button",
      "label": "Prepare missing clear",
      "action": {
        "type": "contract-call",
        "contract": "BicycleComponentManager",
        "function": "clearMissing",
        "args": [
          "$form.serialNumber"
        ],
        "onSuccess": {
          "type": "navigate",
          "route": "component",
          "params": {
            "serialNumber": "$form.serialNumber"
          }
        }
      }
    },
    {
      "type": "button",
      "label": "Prepare retirement",
      "action": {
        "type": "contract-call",
        "contract": "BicycleComponentManager",
        "function": "retireComponent",
        "args": [
          "$form.serialNumber"
        ],
        "onSuccess": {
          "type": "navigate",
          "route": "component",
          "params": {
            "serialNumber": "$form.serialNumber"
          }
        }
      }
    }
  ]
}
