{
  "screen": "1.0.0-tentative",
  "title": "Bicycle component registry",
  "catalogs": {
    "navigationActions": "../catalogs/navigation.actions.json"
  },
  "tree": {
    "type": "Screen",
    "props": {
      "title": "Bicycle component registry"
    },
    "children": [
      {
        "type": "Region",
        "props": {
          "name": "main"
        },
        "children": [
          {
            "type": "Text",
            "props": {
              "text": "Look up a component by the serial number stamped on the bicycle."
            }
          },
          {
            "type": "Address",
            "props": {
              "label": "Connected account",
              "address": "$account.address"
            }
          },
          {
            "type": "Status",
            "props": {
              "label": "Can register components",
              "value": "$values.0.canRegister"
            }
          },
          {
            "type": "Input",
            "props": {
              "name": "serialNumber",
              "label": "Serial number",
              "value": ""
            }
          }
        ]
      },
      {
        "type": "Region",
        "props": {
          "name": "actions"
        },
        "children": [
          {
            "type": "Include",
            "from": "navigationActions",
            "select": ["lookupComponent", "openRegister"]
          }
        ]
      }
    ]
  }
}

