{
  "screen": "1.0.0-tentative",
  "title": "Component",
  "catalogs": {
    "componentViews": "../catalogs/component.views.json",
    "componentActions": "../catalogs/component.actions.json",
    "navigationActions": "../catalogs/navigation.actions.json"
  },
  "tree": {
    "type": "Screen",
    "props": {
      "title": "Component"
    },
    "children": [
      {
        "type": "Region",
        "props": {
          "name": "main"
        },
        "children": [
          {
            "type": "Include",
            "from": "componentViews",
            "select": "$values.0.view"
          }
        ]
      },
      {
        "type": "Region",
        "props": {
          "name": "actions"
        },
        "children": [
          {
            "type": "Include",
            "from": "componentActions",
            "select": "$values.0.actions",
            "order": ["updateMetadata", "markMissing", "clearMissing", "retire"]
          },
          {
            "type": "Include",
            "from": "navigationActions",
            "select": ["lookupComponent", "openRegister"]
          }
        ]
      }
    ]
  }
}

