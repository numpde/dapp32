{
  "catalog": "1.0.0-tentative",
  "role": "actions",
  "items": {
    "lookupComponent": {
      "type": "Action",
      "props": {
        "label": "Look up component",
        "action": {
          "type": "navigate",
          "route": "component",
          "params": {
            "serialNumber": "$form.serialNumber"
          }
        }
      }
    },
    "openComponent": {
      "type": "Action",
      "props": {
        "label": "Open component",
        "action": {
          "type": "navigate",
          "route": "component",
          "params": {
            "serialNumber": "$form.serialNumber"
          }
        }
      }
    },
    "openRegister": {
      "type": "Action",
      "props": {
        "label": "Register component",
        "action": {
          "type": "navigate",
          "route": "register",
          "params": {
            "serialNumber": "$form.serialNumber"
          }
        }
      }
    }
  }
}

