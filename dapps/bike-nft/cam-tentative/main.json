{
  "cam": "1.0.0-tentative",
  "entry": "entry",
  "namespaces": {
    "contracts.BicycleComponentManagerUI": {
      "type": "contract",
      "abiURI": "./abi/BicycleComponentManagerUI.json"
    },
    "contracts.BicycleComponentManager": {
      "type": "contract",
      "abiURI": "./abi/BicycleComponentManager.json"
    },
    "routes": {
      "type": "routes"
    },
    "ui": {
      "type": "ui",
      "uri": "./ui.json"
    }
  },
  "routes": {
    "entry": {
      "inputs": [],
      "first": {
        "namespace": "contracts.BicycleComponentManagerUI",
        "function": "viewEntry",
        "args": {
          "account": "$account.address"
        }
      },
      "then": {
        "namespace": "ui",
        "function": "app",
        "args": {
          "account": "$account",
          "form": "$form",
          "input": "$inputs",
          "view": "$outputs.0"
        }
      }
    },
    "component": {
      "inputs": ["serialNumber"],
      "first": {
        "namespace": "contracts.BicycleComponentManagerUI",
        "function": "viewComponent",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "account": "$account.address"
        }
      },
      "then": {
        "namespace": "ui",
        "function": "app",
        "args": {
          "account": "$account",
          "form": "$form",
          "input": "$inputs",
          "view": "$outputs.0"
        }
      }
    },
    "register": {
      "inputs": ["serialNumber"],
      "first": {
        "namespace": "contracts.BicycleComponentManagerUI",
        "function": "viewRegister",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "account": "$account.address"
        }
      },
      "then": {
        "namespace": "ui",
        "function": "app",
        "args": {
          "account": "$account",
          "form": "$form",
          "input": "$inputs",
          "view": "$outputs.0"
        }
      }
    },
    "registerComponent": {
      "inputs": ["serialNumber", "tokenURI"],
      "first": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "registerComponent",
        "args": {
          "owner": "$account.address",
          "serialNumber": "$inputs.serialNumber",
          "tokenURI_": "$inputs.tokenURI"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "updateComponentMetadata": {
      "inputs": ["serialNumber", "tokenURI"],
      "first": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "setComponentMetadata",
        "args": {
          "serialNumber": "$inputs.serialNumber",
          "tokenURI_": "$inputs.tokenURI"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "markComponentMissing": {
      "inputs": ["serialNumber"],
      "first": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "markMissing",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "clearComponentMissing": {
      "inputs": ["serialNumber"],
      "first": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "clearMissing",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "retireComponent": {
      "inputs": ["serialNumber"],
      "first": {
        "namespace": "contracts.BicycleComponentManager",
        "function": "retireComponent",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      },
      "then": {
        "namespace": "routes",
        "function": "component",
        "args": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    }
  }
}
