{
  "cam": "1.0.0-tentative",
  "entry": "entry",
  "contracts": {
    "BicycleComponentManagerUI": {
      "abiURI": "./abi/BicycleComponentManagerUI.json"
    },
    "BicycleComponentManager": {
      "abiURI": "./abi/BicycleComponentManager.json"
    }
  },
  "routes": {
    "entry": {
      "inputs": [],
      "first": {
        "contract": "BicycleComponentManagerUI",
        "function": "viewEntry",
        "args": ["$account.address"]
      }
    },
    "component": {
      "inputs": ["serialNumber"],
      "first": {
        "contract": "BicycleComponentManagerUI",
        "function": "viewComponent",
        "args": ["$inputs.serialNumber", "$account.address"]
      }
    },
    "register": {
      "inputs": ["serialNumber"],
      "first": {
        "contract": "BicycleComponentManagerUI",
        "function": "viewRegister",
        "args": ["$inputs.serialNumber", "$account.address"]
      }
    },
    "registerComponent": {
      "inputs": ["serialNumber", "tokenURI"],
      "first": {
        "contract": "BicycleComponentManager",
        "function": "registerComponent",
        "args": ["$account.address", "$inputs.serialNumber", "$inputs.tokenURI"]
      },
      "then": {
        "to": "component",
        "inputs": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "updateComponentMetadata": {
      "inputs": ["serialNumber", "tokenURI"],
      "first": {
        "contract": "BicycleComponentManager",
        "function": "setComponentMetadata",
        "args": ["$inputs.serialNumber", "$inputs.tokenURI"]
      },
      "then": {
        "to": "component",
        "inputs": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "markComponentMissing": {
      "inputs": ["serialNumber"],
      "first": {
        "contract": "BicycleComponentManager",
        "function": "markMissing",
        "args": ["$inputs.serialNumber"]
      },
      "then": {
        "to": "component",
        "inputs": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "clearComponentMissing": {
      "inputs": ["serialNumber"],
      "first": {
        "contract": "BicycleComponentManager",
        "function": "clearMissing",
        "args": ["$inputs.serialNumber"]
      },
      "then": {
        "to": "component",
        "inputs": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    },
    "retireComponent": {
      "inputs": ["serialNumber"],
      "first": {
        "contract": "BicycleComponentManager",
        "function": "retireComponent",
        "args": ["$inputs.serialNumber"]
      },
      "then": {
        "to": "component",
        "inputs": {
          "serialNumber": "$inputs.serialNumber"
        }
      }
    }
  },
  "resources": {
    "ui": "./ui.json"
  }
}
