{
  "ui": "1.0.0-tentative",
  "app": {
    "tag": "Screen",
    "requires": ["account", "form", "input", "view"],
    "props": {
      "title": "Bicycle component registry"
    },
    "children": [
      {
        "tag": "Include",
        "first": {
          "namespace": "ui",
          "function": "$view.view",
          "args": {
            "account": "$account",
            "input": "$input",
            "view": "$view"
          }
        }
      },
      {
        "tag": "Include",
        "first": {
          "namespace": "ui",
          "function": "$view.actions",
          "args": {
            "form": "$form"
          }
        }
      }
    ]
  },
  "entry": {
    "requires": ["account", "view"],
    "tag": "Fragment",
    "children": [
      {
        "tag": "Text",
        "props": {
          "text": "Look up a component by the serial number stamped on the bicycle."
        }
      },
      {
        "tag": "Address",
        "props": {
          "label": "Connected account",
          "address": "$account.address"
        }
      },
      {
        "tag": "Status",
        "props": {
          "label": "Can register components",
          "value": "$view.canRegister"
        }
      },
      {
        "tag": "Input",
        "props": {
          "name": "serialNumber",
          "label": "Serial number",
          "value": ""
        }
      }
    ]
  },
  "component.empty": {
    "requires": ["input"],
    "tag": "Fragment",
    "children": [
      {
        "tag": "Text",
        "props": {
          "text": "Enter a bicycle component serial number."
        }
      },
      {
        "tag": "Input",
        "props": {
          "name": "serialNumber",
          "label": "Serial number",
          "value": "$input.serialNumber"
        }
      }
    ]
  },
  "component.notFound": {
    "requires": ["view"],
    "tag": "Fragment",
    "children": [
      {
        "tag": "Input",
        "props": {
          "name": "serialNumber",
          "label": "Serial number",
          "value": "$view.serialNumber"
        }
      },
      {
        "tag": "Status",
        "props": {
          "label": "Registered",
          "value": false
        }
      }
    ]
  },
  "component.found": {
    "requires": ["view"],
    "tag": "Fragment",
    "children": [
      {
        "tag": "Input",
        "props": {
          "name": "serialNumber",
          "label": "Serial number",
          "value": "$view.serialNumber"
        }
      },
      {
        "tag": "Status",
        "props": {
          "label": "Status",
          "value": "$view.status"
        }
      },
      {
        "tag": "Address",
        "props": {
          "label": "Owner",
          "address": "$view.owner"
        }
      },
      {
        "tag": "Status",
        "props": {
          "label": "Owner info",
          "value": "$view.ownerInfo"
        }
      },
      {
        "tag": "Nft",
        "props": {
          "contractAddress": "$view.tokenContract",
          "tokenId": "$view.tokenId"
        }
      },
      {
        "tag": "Status",
        "props": {
          "label": "Token URI",
          "value": "$view.tokenURI"
        }
      },
      {
        "tag": "Input",
        "props": {
          "name": "tokenURI",
          "label": "New token URI",
          "value": "$view.tokenURI"
        }
      },
      {
        "tag": "Status",
        "props": {
          "label": "Serial hash",
          "value": "$view.serialHash"
        }
      }
    ]
  },
  "register.empty": {
    "requires": ["input"],
    "tag": "Fragment",
    "children": [
      {
        "tag": "Text",
        "props": {
          "text": "Enter a serial number before preparing registration."
        }
      },
      {
        "tag": "Input",
        "props": {
          "name": "serialNumber",
          "label": "Serial number",
          "value": "$input.serialNumber"
        }
      },
      {
        "tag": "Input",
        "props": {
          "name": "tokenURI",
          "label": "Token URI",
          "value": ""
        }
      }
    ]
  },
  "register.ready": {
    "requires": ["view"],
    "tag": "Fragment",
    "children": [
      {
        "tag": "Input",
        "props": {
          "name": "serialNumber",
          "label": "Serial number",
          "value": "$view.serialNumber"
        }
      },
      {
        "tag": "Input",
        "props": {
          "name": "tokenURI",
          "label": "Token URI",
          "value": ""
        }
      },
      {
        "tag": "Address",
        "props": {
          "label": "Component contract",
          "address": "$view.componentsAddress"
        }
      },
      {
        "tag": "Status",
        "props": {
          "label": "Account info",
          "value": "$view.accountInfo"
        }
      }
    ]
  },
  "register.blocked": {
    "requires": ["view"],
    "tag": "Fragment",
    "children": [
      {
        "tag": "Input",
        "props": {
          "name": "serialNumber",
          "label": "Serial number",
          "value": "$view.serialNumber"
        }
      },
      {
        "tag": "Status",
        "props": {
          "label": "Connected account can register",
          "value": "$view.canRegister"
        }
      },
      {
        "tag": "Status",
        "props": {
          "label": "Component already exists",
          "value": "$view.exists"
        }
      },
      {
        "tag": "Status",
        "props": {
          "label": "Account info",
          "value": "$view.accountInfo"
        }
      }
    ]
  },
  "lookupComponent": {
    "requires": ["form"],
    "tag": "Action",
    "props": {
      "label": "Look up component"
    },
    "first": {
      "namespace": "routes",
      "function": "component",
      "args": {
        "serialNumber": "$form.serialNumber"
      }
    }
  },
  "openRegister": {
    "requires": ["form"],
    "tag": "Action",
    "props": {
      "label": "Register component"
    },
    "first": {
      "namespace": "routes",
      "function": "register",
      "args": {
        "serialNumber": "$form.serialNumber"
      }
    }
  },
  "register": {
    "requires": ["form"],
    "tag": "Action",
    "props": {
      "label": "Prepare registration"
    },
    "first": {
      "namespace": "routes",
      "function": "registerComponent",
      "args": {
        "serialNumber": "$form.serialNumber",
        "tokenURI": "$form.tokenURI"
      }
    }
  },
  "updateMetadata": {
    "requires": ["form"],
    "tag": "Action",
    "props": {
      "label": "Prepare metadata update"
    },
    "first": {
      "namespace": "routes",
      "function": "updateComponentMetadata",
      "args": {
        "serialNumber": "$form.serialNumber",
        "tokenURI": "$form.tokenURI"
      }
    }
  },
  "markMissing": {
    "requires": ["form"],
    "tag": "Action",
    "props": {
      "label": "Prepare missing report"
    },
    "first": {
      "namespace": "routes",
      "function": "markComponentMissing",
      "args": {
        "serialNumber": "$form.serialNumber"
      }
    }
  },
  "clearMissing": {
    "requires": ["form"],
    "tag": "Action",
    "props": {
      "label": "Prepare missing clear"
    },
    "first": {
      "namespace": "routes",
      "function": "clearComponentMissing",
      "args": {
        "serialNumber": "$form.serialNumber"
      }
    }
  },
  "retire": {
    "requires": ["form"],
    "tag": "Action",
    "props": {
      "label": "Prepare retirement"
    },
    "first": {
      "namespace": "routes",
      "function": "retireComponent",
      "args": {
        "serialNumber": "$form.serialNumber"
      }
    }
  }
}
