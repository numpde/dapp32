{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "exactOptionalPropertyTypes": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmitOnError": true,
    "rewriteRelativeImportExtensions": true,
    "strict": true,
    "target": "ES2022",
    "verbatimModuleSyntax": true
  }
}
