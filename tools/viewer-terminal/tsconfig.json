{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "exactOptionalPropertyTypes": true,
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "typeRoots": [
      "../../packages/node_modules/@types"
    ],
    "types": [
      "node"
    ],
    "verbatimModuleSyntax": true
  },
  "include": [
    "**/*.ts"
  ]
}
