# Local environment files can contain RPC URLs, tokens, private keys, or other
# operator-specific secrets. Keep only explicit examples tracked.
.env
.env.*
!.env.example

# Compose-local environment files are machine-specific and may contain secrets.
compose/**/.env

# Foundry outputs are generated by build/test/deploy lanes.
on-chain/cache/
on-chain/out/
on-chain/broadcast/

# Keep common root-level generated outputs and reports out of version control.
cache/
out/
broadcast/
reports/

# Package manager installs and local Solidity dependency materialization are
# reproducible from committed manifests/locks, not source of truth themselves.
node_modules/
/on-chain/dependencies/

# JetBrains IDE project state is local editor configuration.
.idea/
